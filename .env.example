# Discord webhook URL for eBPF alerts (required).
# Create an Incoming Webhook in your Discord server (e.g. #bot-logs or #sentinel-alerts)
# or use the SL1C3D Discord_Server_Config provision script — see docs/DISCORD-SETUP.md
DISCORD_WEBHOOK_URL=

# Optional: if you use Discord_Server_Config and provision the "Tetragon Sentinel" webhook,
# you can set this instead and leave DISCORD_WEBHOOK_URL unset
# DISCORD_WEBHOOK_SENTINEL=
